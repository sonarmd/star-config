{
  "name": "@sonarmd/star-config",
  "version": "4.0.0",
  "description": "Opinionated, preconfigured dev tooling for SonarMD JavaScript and TypeScript projects.",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    "./eslint": "./eslint/flat.mjs",
    "./eslint/flat": "./eslint/flat.mjs",
    "./eslint/legacy": "./eslint/legacy.cjs",
    "./eslint/sonar": "./eslint/sonar.mjs",
    "./eslint/security": "./eslint/security.mjs",
    "./eslint/iac": "./eslint/iac.mjs",
    "./prettier": "./prettier.config.cjs",
    "./tsconfig/base": "./tsconfig/base.json",
    "./tsconfig/node18": "./tsconfig/node18.json",
    "./tsconfig/node20": "./tsconfig/node20.json",
    "./tsconfig/node22": "./tsconfig/node22.json",
    "./tsconfig/react-app": "./tsconfig/react-app.json",
    "./tsconfig/node-api": "./tsconfig/node-api.json",
    "./tsconfig/library": "./tsconfig/library.json",
    "./lint-staged": "./lint-staged.config.cjs",
    "./commitlint": "./commitlint.config.cjs",
    "./husky/install": "./husky/install.mjs",
    "./iac/detect": {
      "import": "./dist/iac/detect.js",
      "types": "./dist/iac/detect.d.ts"
    },
    "./iac/cdk-nag": {
      "import": "./dist/iac/cdk-nag.js",
      "types": "./dist/iac/cdk-nag.d.ts"
    },
    "./dependabot/install": "./dependabot/install.mjs",
    "./repo-setup/install": "./repo-setup/install.mjs",
    "./semgrep/baseline": "./semgrep/baseline.yml",
    "./gitleaks/default": "./gitleaks/default.toml",
    "./trivy/config": "./trivy/config.yaml",
    "./security/install": "./dist/security/install.js",
    "./jscpd/default": "./jscpd/default.json",
    "./knip/default": "./knip/default.json",
    "./quality/coverage": {
      "import": "./dist/quality/coverage.js",
      "types": "./dist/quality/coverage.d.ts"
    }
  },
  "files": [
    "eslint/",
    "tsconfig/",
    "husky/",
    "dist/",
    "prettier.config.cjs",
    "lint-staged.config.cjs",
    "commitlint.config.cjs",
    "dependabot/",
    "repo-setup/",
    "semgrep/",
    "gitleaks/",
    "trivy/",
    "jscpd/",
    "knip/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint . && prettier --check .",
    "test": "yarn build && node --test 'test/*.test.mjs'",
    "prepare": "yarn build",
    "prepublishOnly": "yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonarmd/star-config.git"
  },
  "author": "SonarMD <engineering@sonarmd.com>",
  "license": "UNLICENSED",
  "peerDependencies": {
    "cdk-nag": ">=2.28.0",
    "eslint": ">=9.0.0",
    "prettier": ">=3.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "cdk-nag": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": ">=2.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.7.0"
  }
}
