{
  "name": "@sonarmd/star-config",
  "version": "3.2.0",
  "description": "Opinionated, preconfigured dev tooling for SonarMD JavaScript and TypeScript projects.",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "exports": {
    "./eslint": "./eslint/flat.mjs",
    "./eslint/flat": "./eslint/flat.mjs",
    "./eslint/legacy": "./eslint/legacy.cjs",
    "./eslint/sonar": "./eslint/sonar.mjs",
    "./eslint/security": "./eslint/security.mjs",
    "./eslint/iac": "./eslint/iac.mjs",
    "./prettier": "./prettier.config.cjs",
    "./tsconfig/base": "./tsconfig/base.json",
    "./tsconfig/node18": "./tsconfig/node18.json",
    "./tsconfig/node20": "./tsconfig/node20.json",
    "./tsconfig/node22": "./tsconfig/node22.json",
    "./tsconfig/react-app": "./tsconfig/react-app.json",
    "./tsconfig/node-api": "./tsconfig/node-api.json",
    "./tsconfig/library": "./tsconfig/library.json",
    "./lint-staged": "./lint-staged.config.cjs",
    "./commitlint": "./commitlint.config.cjs",
    "./husky/install": "./husky/install.mjs",
    "./iac/detect": {
      "import": "./dist/detect.js",
      "types": "./dist/detect.d.ts"
    },
    "./iac/cdk-nag": {
      "import": "./dist/cdk-nag.js",
      "types": "./dist/cdk-nag.d.ts"
    },
    "./dependabot/install": "./dependabot/install.mjs",
    "./repo-setup/install": "./repo-setup/install.mjs"
  },
  "files": [
    "eslint/",
    "tsconfig/",
    "husky/",
    "iac/",
    "dist/",
    "tsconfig.build.json",
    "prettier.config.cjs",
    "lint-staged.config.cjs",
    "commitlint.config.cjs",
    "dependabot/",
    "repo-setup/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint . && prettier --check .",
    "test": "yarn build && node --test 'test/*.test.mjs'",
    "prepare": "husky",
    "prepublishOnly": "yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonarmd/star-config.git"
  },
  "author": "SonarMD <engineering@sonarmd.com>",
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "@commitlint/cli": ">=19.0.0",
    "@commitlint/config-conventional": ">=19.0.0",
    "@eslint/js": ">=9.0.0",
    "@typescript-eslint/eslint-plugin": ">=8.0.0",
    "@typescript-eslint/parser": ">=8.0.0",
    "cdk-nag": ">=2.28.0",
    "eslint": ">=9.0.0",
    "eslint-config-prettier": ">=9.0.0",
    "eslint-plugin-import": ">=2.30.0",
    "eslint-plugin-react": ">=7.35.0",
    "eslint-plugin-react-hooks": ">=5.0.0",
    "eslint-plugin-security": ">=4.0.0",
    "eslint-plugin-sonarjs": ">=0.25.0",
    "globals": ">=15.0.0",
    "husky": ">=9.0.0",
    "prettier": ">=3.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@commitlint/cli": { "optional": true },
    "@commitlint/config-conventional": { "optional": true },
    "@typescript-eslint/eslint-plugin": { "optional": true },
    "@typescript-eslint/parser": { "optional": true },
    "cdk-nag": { "optional": true },
    "eslint-plugin-react": { "optional": true },
    "eslint-plugin-react-hooks": { "optional": true },
    "husky": { "optional": true },
    "typescript": { "optional": true }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": ">=0.25.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.7.0"
  }
}
