{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@sonarmd/star-config — TypeScript base",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "noImplicitAny": false,
    "sourceMap": true,
    "declaration": false,
    "incremental": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "out",
    ".next",
    "coverage",
    ".claude",
    "cdk.out"
  ]
}
