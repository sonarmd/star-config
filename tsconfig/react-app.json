{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@sonarmd/star-config — React app (CRA / Vite)",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "noEmit": true
  }
}
