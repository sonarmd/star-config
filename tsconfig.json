{
  "compilerOptions": {
    "incremental": true,
    "module": "commonjs",
    "noEmit": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "target": "es6",
    "noImplicitAny": false,
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@modelInterfaces": [
        "./modelInterfaces"
      ],
      "@interfaces": [
        "./Interfaces"
      ]
    },
    "lib": [
      "es2017",
      "dom",
      "es2017.object"
    ],
    "typeRoots": [
      "./types",
      "./node_modules/@types"
    ]
  }
}
